WELCOME_MESSAGE = (
    "Welcome to DineFlow. I'm your AI ordering assistant.\n\n"
    "Try asking:\n"
    "  • \"anything spicy?\"\n"
    "  • \"add 2 pepperoni pizzas\"\n"
    "  • \"what's on the menu?\""
)


def build_interface():
    with gr.Blocks(title="DineFlow", css=CUSTOM_CSS) as demo:

        gr.HTML("""
        <div class="dineflow-header">
            <h1>DineFlow</h1>
            <p>AI-powered restaurant ordering</p>
        </div>
        """)

        # Persistent state — survives within a tab session
        session_state = gr.State({})
        memory_state  = gr.State({"window": []})

        with gr.Row():
            with gr.Column(scale=3):
                chatbot = gr.Chatbot(
                    value=[],
                    type="messages",
                    elem_id="chatbox",
                    height=500,
                    show_label=False,
                )
                with gr.Row():
                    msg_input = gr.Textbox(
                        placeholder="Type your order or question...",
                        show_label=False,
                        elem_id="msg-input",
                        scale=5,
                        container=False,
                    )
                    send_btn = gr.Button("Send →", elem_id="send-btn", scale=1, min_width=80)

            with gr.Column(scale=1):
                status_box = gr.Textbox(
                    label="Session Status",
                    value="Loading...",
                    elem_id="status-panel",
                    interactive=False,
                    lines=10,
                )
                new_btn = gr.Button("↺ New Session", elem_id="new-session-btn")

        # ── on_load: fires on every page load including reloads ────────────────
        # Strategy: on_load() always returns the uid. A hidden Textbox carries
        # it to a JS change-listener that redirects the browser to ?uid=<uid>
        # if the param isn't already in the URL.
        #
        # Using a gr.Textbox change trigger instead of .then() because .then()
        # fires before gr.State values propagate to JS inputs in Gradio 5.x,
        # causing uid to arrive as null. The change event fires only after the
        # component value is set, so the uid is always populated.
        uid_box = gr.Textbox(visible=False, elem_id="uid-box")

        demo.load(
            on_load,
            inputs=[],
            outputs=[chatbot, session_state, memory_state, status_box, uid_box]
        )

        uid_box.change(
            fn=None,
            inputs=[uid_box],
            js="""(uid) => {
                if (!uid || uid === 'null') return;
                const params = new URLSearchParams(window.location.search);
                if (!params.get('uid')) {
                    window.location.href = window.location.pathname + '?uid=' + uid;
                }
            }"""
        )

        # Prevent multiline input at the UI level.
        # Intercepts Enter key on the textarea and strips any newlines that
        # slip through (e.g. from copy-paste). Plain Enter submits the form.
        # Shift+Enter is also blocked — users should not be able to enter
        # multi-line orders since the system handles one intent per turn.
        gr.HTML("""
        <script>
        document.addEventListener('DOMContentLoaded', () => {
            function attachInputGuard() {
                const textarea = document.querySelector('#msg-input textarea');
                if (!textarea) { setTimeout(attachInputGuard, 300); return; }

                // Strip newlines on every input event (handles paste)
                textarea.addEventListener('input', () => {
                    const pos = textarea.selectionStart;
                    const cleaned = textarea.value.replace(/\n/g, ' ').replace(/\r/g, '');
                    if (cleaned !== textarea.value) {
                        textarea.value = cleaned;
                        textarea.setSelectionRange(pos, pos);
                    }
                });

                // Block Shift+Enter producing newlines
                textarea.addEventListener('keydown', (e) => {
                    if (e.key === 'Enter' && e.shiftKey) {
                        e.preventDefault();
                    }
                });
            }
            attachInputGuard();
        });
        </script>
        """)

        # ── send message ───────────────────────────────────────────────────────
        send_inputs  = [msg_input, chatbot, session_state, memory_state]
        send_outputs = [chatbot, session_state, memory_state, msg_input, status_box]

        send_btn.click(chat, inputs=send_inputs, outputs=send_outputs)
        msg_input.submit(chat, inputs=send_inputs, outputs=send_outputs)

        # ── new session: reset state and redirect to ?uid=<new> ───────────────
        new_btn.click(
            new_session,
            inputs=[],
            outputs=[chatbot, session_state, memory_state, msg_input, status_box, uid_box]
        )
        # uid_box.change handles the redirect automatically

    return demo


if __name__ == "__main__":
    demo = build_interface()
    demo.launch(server_name="0.0.0.0", server_port=7860, show_error=True)