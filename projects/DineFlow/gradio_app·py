# projects/DineFlow/gradio_app.py
import uuid
import json
import warnings
import os
import gradio as gr
from state_machine.types import SessionState, KitchenSnapshot
from orchestration.golden_loop import golden_loop
from orchestration.memory_manager import MemoryManager

os.environ["TOKENIZERS_PARALLELISM"] = "false"
warnings.filterwarnings("ignore", category=FutureWarning, module="huggingface_hub")

BASE_DIR = os.path.dirname(os.path.abspath(__file__))
STATE_DB_PATH = os.path.join(BASE_DIR, "session_store.json")


# ── Session Persistence ────────────────────────────────────────────────────────

def get_session_for_user(user_id: str) -> SessionState:
    if os.path.exists(STATE_DB_PATH):
        with open(STATE_DB_PATH, "r") as f:
            try:
                data = json.load(f)
                for sess_id, state in data.items():
                    if state.get("user_id") == user_id and state.get("order_status") == "DRAFT":
                        return SessionState(**state)
            except json.JSONDecodeError:
                pass
    return SessionState(
        session_id=f"sess-{str(uuid.uuid4())[:4]}",
        user_id=user_id,
        active_agent="OrderTaker",
        tool_budget_remaining=5
    )


def save_session_state(session: SessionState):
    data = {}
    try:
        if os.path.exists(STATE_DB_PATH):
            with open(STATE_DB_PATH, "r") as f:
                content = f.read()
                data = json.loads(content) if content else {}
        data[session.session_id] = session.model_dump()
        with open(STATE_DB_PATH, "w") as f:
            json.dump(data, f, indent=2)
    except Exception as e:
        print(f"Critical: Could not save session state: {e}")


def load_chat_history(session_id: str) -> list:
    """
    Rebuilds chat history from session_store for display on reload.

    We store the full turn history under session_store[session_id]["history"]
    as a list of {"role": ..., "content": ...} dicts — the same format
    Gradio's Chatbot expects. On reload, we read this back and restore
    the visual history so the user sees their prior conversation.

    This is separate from memory_manager.window (short-term sliding window
    for LLM context) and ChromaDB (long-term semantic retrieval). This is
    purely the display layer.
    """
    if not os.path.exists(STATE_DB_PATH):
        return []
    try:
        with open(STATE_DB_PATH, "r") as f:
            data = json.load(f)
        for sess_id, state in data.items():
            if sess_id == session_id:
                return state.get("history", [])
    except (json.JSONDecodeError, KeyError):
        pass
    return []


def save_chat_history(session_id: str, history: list):
    """Persists the display history alongside session state."""
    if not os.path.exists(STATE_DB_PATH):
        return
    try:
        with open(STATE_DB_PATH, "r") as f:
            data = json.load(f)
        if session_id in data:
            data[session_id]["history"] = history
            with open(STATE_DB_PATH, "w") as f:
                json.dump(data, f, indent=2)
    except Exception as e:
        print(f"Critical: Could not save chat history: {e}")


def format_cart(cart: dict, all_menu_items) -> str:
    if not cart:
        return "Empty"
    item_map = {item.sku: item.name for item in all_menu_items}
    lines = [f"• {item_map.get(sku, sku)} × {qty}" for sku, qty in cart.items()]
    return "\n".join(lines)


def build_status(session: SessionState, kitchen: KitchenSnapshot, all_menu_items) -> str:
    cart_str = format_cart(session.cart, all_menu_items)
    return (
        f"🤖 Agent: {session.active_agent}\n"
        f"🎯 Budget: {session.tool_budget_remaining}/5\n"
        f"🍳 Kitchen: {kitchen.load_percentage}%\n"
        f"📋 Session: {session.session_id}\n\n"
        f"🛒 Cart:\n{cart_str}"
    )


# ── Core Chat Handler ──────────────────────────────────────────────────────────

def chat(user_message: str, history: list, session_state: dict, memory_state: dict):
    """
    Stateless handler called by Gradio on each message.
    Session, memory, and chat history are all persisted to disk so they
    survive page reloads. On reload, on_load() rehydrates them.
    """
    # Sanitize input — collapse multiline pastes into a single line.
    # Users sometimes paste multiple items (one per line) which the LLM
    # receives as a single ambiguous string it cannot reliably split.
    # Joining with a comma gives the LLM a parseable list while preserving
    # all item names — much better than silently dropping extra lines.
    user_message = ", ".join(
        line.strip() for line in user_message.splitlines() if line.strip()
    )

    if not user_message.strip():
        return history, session_state, memory_state, "", ""

    session = SessionState(**session_state)
    memory = MemoryManager(session_id=session.session_id)
    memory.window = memory_state.get("window", [])
    kitchen = KitchenSnapshot(load_percentage=40)

    try:
        response = golden_loop(
            session=session,
            user_input=user_message,
            kitchen=kitchen,
            memory=memory
        )
        save_session_state(session)
    except Exception as e:
        response = f"⚠️ System error: {e}"

    history.append({"role": "user", "content": user_message})
    history.append({"role": "assistant", "content": response})

    # Persist display history so reload can restore it
    save_chat_history(session.session_id, history)

    # Persist the short-term memory window so on_load() can restore LLM context on reload
    if os.path.exists(STATE_DB_PATH):
        try:
            with open(STATE_DB_PATH, "r") as f:
                _data = json.load(f)
            if session.session_id in _data:
                _data[session.session_id]["memory_window"] = memory.window
                with open(STATE_DB_PATH, "w") as f:
                    json.dump(_data, f, indent=2)
        except Exception:
            pass

    from orchestration.golden_loop import all_menu_items
    status = build_status(session, kitchen, all_menu_items)

    return (
        history,
        session.model_dump(),
        {"window": memory.window},
        "",
        status
    )


def on_load(request: gr.Request):
    """
    Fires on every page load (initial load and reload).

    Isolation strategy:
        Each browser tab gets a unique user_id via the 'uid' query param.
        On first load:  ?uid is absent → generate a new uid, create fresh session
        On reload:      ?uid=<existing> → look up session in session_store.json,
                        restore session state, memory window, and chat history

    This gives each tab a stable identity across reloads without requiring
    browser cookies or localStorage. Users can also bookmark
    http://localhost:7860/?uid=<their-uid> to return to a specific session.

    Simultaneous tabs:
        Each tab passes a different uid, so they each get their own
        SessionState and MemoryManager.window — fully isolated.
    """
    from orchestration.golden_loop import all_menu_items

    uid = request.query_params.get("uid", None)
    if not uid:
        uid = f"guest_{str(uuid.uuid4())[:8]}"

    session = get_session_for_user(uid)
    history = load_chat_history(session.session_id)
    kitchen = KitchenSnapshot(load_percentage=40)

    # Restore memory window from session store if available
    memory_window = []
    if os.path.exists(STATE_DB_PATH):
        try:
            with open(STATE_DB_PATH, "r") as f:
                data = json.load(f)
            for sess_id, state in data.items():
                if sess_id == session.session_id:
                    memory_window = state.get("memory_window", [])
                    break
        except Exception:
            pass

    if not history:
        history = [{"role": "assistant", "content": WELCOME_MESSAGE}]

    status = build_status(session, kitchen, all_menu_items)

    # Return uid so the JS redirect can append it to the URL
    return (
        history,
        session.model_dump(),
        {"window": memory_window},
        status,
        uid
    )


def new_session():
    """Resets to a fresh session."""
    from orchestration.golden_loop import all_menu_items
    uid = f"guest_{str(uuid.uuid4())[:8]}"
    session = get_session_for_user(uid)
    kitchen = KitchenSnapshot(load_percentage=40)
    history = [{"role": "assistant", "content": "🆕 New session started. How can I help you?"}]
    status = build_status(session, kitchen, all_menu_items)
    return history, session.model_dump(), {"window": []}, "", status, uid


